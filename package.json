{
    "name": "codesenseisearch",
    "version": "0.1.0",
    "description": "AI-powered semantic search engine for developer content",
    "private": true,
    "scripts": {
        "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter api dev\"",
        "build": "pnpm --filter \"*\" build",
        "test": "pnpm --filter \"*\" test",
        "lint": "pnpm --filter \"*\" lint",
        "type-check": "pnpm --filter \"*\" type-check",
        "db:migrate": "pnpm --filter api db:migrate",
        "db:studio": "pnpm --filter api db:studio",
        "clean": "pnpm --filter \"*\" clean",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "concurrently": "^8.2.2",
        "eslint": "^8.57.0",
        "prettier": "^3.0.3",
        "typescript": "^5.3.0",
        "husky": "^8.0.3",
        "lint-staged": "^15.0.0"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.17.1",
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}