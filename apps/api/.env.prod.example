# Production migration env. Copy to `.env.prod` (gitignored) and paste
# the actual Supabase password into both URLs. Then run:
#
#   pnpm --filter api db:deploy:prod
#
# That single command applies all pending Prisma migrations against the
# live Supabase DB. No other terminal magic needed.

# Pooled connection — port 6543, pgbouncer mode. Used by the runtime.
DATABASE_URL="postgresql://postgres.telynjuvugerjemmknnz:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — port 5432. Used by `prisma migrate deploy`
# because pgbouncer can't proxy Prisma's prepared-statement workflow.
DIRECT_URL="postgresql://postgres.telynjuvugerjemmknnz:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
