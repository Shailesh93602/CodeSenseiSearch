import { Injectable, Logger } from '@nestjs/common';
import { ConfigService } from '@nestjs/config';
import OpenAI from 'openai';

export interface EmbeddingResult {
  content: string;
  embedding: number[];
  tokenCount: number;
  model: string;
  timestamp: Date;
}

export interface EmbeddingBatchResult {
  embeddings: EmbeddingResult[];
  totalTokens: number;
  cost: number;
}

@Injectable()
export class OpenAIService {
  private readonly logger = new Logger(OpenAIService.name);
  private readonly openai: OpenAI;
  private readonly embeddingModel = 'text-embedding-3-small';
  private readonly maxTokensPerChunk = 8191; // text-embedding-3-small limit

  constructor(private configService: ConfigService) {
    const apiKey = this.configService.get<string>('OPENAI_API_KEY');

    if (!apiKey) {
      this.logger.warn(
        'OpenAI API key not found. Embedding generation will be disabled.',
      );
      return;
    }

    this.openai = new OpenAI({
      apiKey: apiKey,
    });

    this.logger.log('OpenAI service initialized');
  }

  /**
   * Generate embedding for a single text chunk
   */
  async generateEmbedding(content: string): Promise<EmbeddingResult> {
    if (!this.openai) {
      throw new Error('OpenAI service not initialized. Check OPENAI_API_KEY.');
    }

    try {
      // Truncate content if too long
      const truncatedContent = this.truncateContent(content);

      const response = await this.openai.embeddings.create({
        model: this.embeddingModel,
        input: truncatedContent,
        encoding_format: 'float',
      });

      const embedding = response.data[0].embedding;
      const tokenCount = response.usage.total_tokens;

      this.logger.debug(`Generated embedding for ${tokenCount} tokens`);

      return {
        content: truncatedContent,
        embedding,
        tokenCount,
        model: this.embeddingModel,
        timestamp: new Date(),
      };
    } catch (error) {
      this.logger.error(`Failed to generate embedding: ${error.message}`);
      throw error;
    }
  }

  /**
   * Generate embeddings for multiple text chunks (batch processing)
   */
  async generateEmbeddingsBatch(
    contents: string[],
  ): Promise<EmbeddingBatchResult> {
    if (!this.openai) {
      throw new Error('OpenAI service not initialized. Check OPENAI_API_KEY.');
    }

    if (contents.length === 0) {
      return { embeddings: [], totalTokens: 0, cost: 0 };
    }

    try {
      // Truncate all content
      const truncatedContents = contents.map((content) =>
        this.truncateContent(content),
      );

      const response = await this.openai.embeddings.create({
        model: this.embeddingModel,
        input: truncatedContents,
        encoding_format: 'float',
      });

      const embeddings: EmbeddingResult[] = response.data.map(
        (item, index) => ({
          content: truncatedContents[index],
          embedding: item.embedding,
          tokenCount: 0, // Individual token count not available in batch
          model: this.embeddingModel,
          timestamp: new Date(),
        }),
      );

      const totalTokens = response.usage.total_tokens;
      const cost = this.calculateCost(totalTokens);

      this.logger.log(
        `Generated ${embeddings.length} embeddings using ${totalTokens} tokens (cost: $${cost.toFixed(4)})`,
      );

      return {
        embeddings,
        totalTokens,
        cost,
      };
    } catch (error) {
      this.logger.error(
        `Failed to generate batch embeddings: ${error.message}`,
      );
      throw error;
    }
  }

  /**
   * Generate embedding for a search query
   */
  async generateQueryEmbedding(query: string): Promise<number[]> {
    const result = await this.generateEmbedding(query);
    return result.embedding;
  }

  /**
   * Calculate cosine similarity between two embeddings
   */
  calculateCosineSimilarity(
    embedding1: number[],
    embedding2: number[],
  ): number {
    if (embedding1.length !== embedding2.length) {
      throw new Error('Embeddings must have the same dimension');
    }

    let dotProduct = 0;
    let norm1 = 0;
    let norm2 = 0;

    for (let i = 0; i < embedding1.length; i++) {
      dotProduct += embedding1[i] * embedding2[i];
      norm1 += embedding1[i] * embedding1[i];
      norm2 += embedding2[i] * embedding2[i];
    }

    norm1 = Math.sqrt(norm1);
    norm2 = Math.sqrt(norm2);

    if (norm1 === 0 || norm2 === 0) {
      return 0;
    }

    return dotProduct / (norm1 * norm2);
  }

  /**
   * Get embedding model information
   */
  getModelInfo() {
    return {
      model: this.embeddingModel,
      dimensions: 1536, // text-embedding-3-small dimensions
      maxTokens: this.maxTokensPerChunk,
      costPer1kTokens: 0.00002, // $0.00002 per 1K tokens
    };
  }

  /**
   * Truncate content to fit within token limits
   */
  private truncateContent(content: string): string {
    // Rough estimation: ~4 characters per token
    const maxChars = this.maxTokensPerChunk * 4;

    if (content.length <= maxChars) {
      return content;
    }

    // Truncate and add indicator
    const truncated = content.substring(0, maxChars - 100);
    return truncated + '\n\n[Content truncated for embedding...]';
  }

  /**
   * Calculate cost based on token usage
   */
  private calculateCost(tokens: number): number {
    const costPer1kTokens = 0.00002;
    return (tokens / 1000) * costPer1kTokens;
  }

  /**
   * Check if OpenAI service is available
   */
  isAvailable(): boolean {
    return !!this.openai;
  }

  /**
   * Get rate limit information (if available)
   */
  async getRateLimitInfo(): Promise<any> {
    if (!this.openai) {
      throw new Error('OpenAI service not initialized');
    }

    try {
      // Make a small test request to get rate limit headers
      await this.openai.embeddings.create({
        model: this.embeddingModel,
        input: 'test',
      });

      return {
        available: true,
        model: this.embeddingModel,
        lastTest: new Date(),
      };
    } catch (error) {
      this.logger.warn(`Rate limit check failed: ${error.message}`);
      return {
        available: false,
        error: error.message,
      };
    }
  }
}