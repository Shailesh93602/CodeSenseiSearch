# Development Environment Variables
# Copy this file to .env and update with your actual values

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/codesenseisearch_dev"

# Redis
REDIS_URL="redis://localhost:6379"

# GitHub API
GITHUB_TOKEN="your_github_personal_access_token_here"

# AI/Embeddings API (choose one)
GEMINI_API_KEY="your_gemini_api_key_here"
# OPENAI_API_KEY="your_openai_api_key_here"  # Alternative to Gemini

# Authentication & Security
JWT_SECRET="your-super-secure-jwt-secret-here-at-least-32-characters"
JWT_REFRESH_SECRET="your-super-secure-refresh-secret-here-different-from-jwt"

# GitHub OAuth (for user authentication)
GITHUB_CLIENT_ID="your_github_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_app_client_secret"
GITHUB_CALLBACK_URL="http://localhost:3001/auth/github/callback"

# Frontend URL (for OAuth redirects)
FRONTEND_URL="http://localhost:3000"

# Application
NODE_ENV="development"
PORT=3001

# Logging
LOG_LEVEL="debug"