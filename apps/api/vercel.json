{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile --shamefully-hoist",
  "buildCommand": "pnpm db:generate && pnpm build && mkdir -p public && echo 'CodeSenseiSearch API — see /api/health for status.' > public/index.txt",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 9 * * *"
    }
  ]
}
