// CodeSenseiSearch Prisma Schema - Phase 2 Enhanced
// Comprehensive schema for content ingestion, embedding storage, and hybrid search

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// User management (from Phase 1)
model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String
  avatar              String?
  githubId            String?  @unique
  emailNotifications  Boolean  @default(true)
  preferredLanguages  String[] @default([])
  preferredRepos      String[] @default([])
  theme               String   @default("system") // light, dark, system
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  favorites           Favorite[]
  searches            Search[]

  @@map("users")
}

// Content Sources (GitHub, StackOverflow, etc.) - Phase 2
model Source {
  id          String   @id @default(cuid())
  name        String   @unique // 'github', 'stackoverflow'
  displayName String   // 'GitHub', 'Stack Overflow'
  type        SourceType
  baseUrl     String?  // API base URL
  isActive    Boolean  @default(true)
  config      Json?    // Source-specific configuration
  
  // Rate limiting settings
  rateLimit   Int?     // Requests per hour
  rateLimitWindow Int? // Window in seconds
  
  // Relationships
  repositories Repository[]
  questions    Question[]
  ingestionJobs IngestionJob[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("sources")
}

// GitHub Repositories - Phase 2
model Repository {
  id          String   @id @default(cuid())
  sourceId    String
  
  // GitHub metadata
  githubId    Int      @unique
  fullName    String   @unique // "owner/repo"
  name        String
  owner       String
  description String?
  
  // Repository stats
  starCount   Int      @default(0)
  forkCount   Int      @default(0)
  language    String?
  size        Int      @default(0) // Size in KB
  
  // URLs and references
  htmlUrl     String
  cloneUrl    String
  defaultBranch String @default("main")
  
  // Ingestion metadata
  lastIngestionAt DateTime?
  ingestionStatus IngestionStatus @default(PENDING)
  ingestionError  String?
  
  // Content statistics
  fileCount      Int @default(0)
  contentCount   Int @default(0)
  chunkCount     Int @default(0)
  embeddingCount Int @default(0)
  
  // Relationships
  source        Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  contents      Content[]
  ingestionJobs IngestionJob[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([sourceId])
  @@index([language])
  @@index([starCount])
  @@index([ingestionStatus])
  @@index([lastIngestionAt])
  @@map("repositories")
}

// StackOverflow Questions - Phase 2
model Question {
  id          String   @id @default(cuid())
  sourceId    String
  
  // StackOverflow metadata
  questionId  Int      @unique
  title       String
  body        String
  tags        String[] // Array of tag names
  
  // Question stats
  score       Int      @default(0)
  viewCount   Int      @default(0)
  answerCount Int      @default(0)
  
  // Status and metadata
  isAnswered  Boolean  @default(false)
  hasAcceptedAnswer Boolean @default(false)
  
  // Ingestion metadata
  lastIngestionAt DateTime?
  ingestionStatus IngestionStatus @default(PENDING)
  ingestionError  String?
  
  // URLs
  htmlUrl     String
  
  // Content statistics
  contentCount   Int @default(0)
  chunkCount     Int @default(0)
  embeddingCount Int @default(0)
  
  // Relationships
  source        Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  contents      Content[]
  ingestionJobs IngestionJob[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([sourceId])
  @@index([tags])
  @@index([score])
  @@index([isAnswered])
  @@index([ingestionStatus])
  @@index([lastIngestionAt])
  @@map("questions")
}

// Enhanced Content model - Phase 2
model Content {
  id          String      @id @default(cuid())
  
  // Content metadata
  title       String
  content     String      @db.Text // Raw content
  contentType ContentType
  language    String?     // Programming language
  
  // File-specific metadata (for GitHub content)
  filePath    String?     // File path in repository
  fileName    String?     // File name
  fileSize    Int?        // Size in bytes
  downloadUrl String?     // Raw download URL
  
  // StackOverflow-specific metadata
  isAnswer    Boolean     @default(false)
  isAccepted  Boolean     @default(false)
  score       Int?        // Answer score
  
  // Content fingerprinting for deduplication
  contentHash String      @unique // SHA256 hash of content
  
  // Processing metadata
  processedAt    DateTime?
  processingError String?
  
  // Content statistics
  chunkCount     Int @default(0)
  embeddingCount Int @default(0)
  
  // Foreign keys (one-to-many relationships)
  repositoryId String?
  questionId   String?
  
  // Relationships
  repository Repository? @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  question   Question?   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  chunks     ContentChunk[]
  embeddings Embedding[]
  favorites  Favorite[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([contentType])
  @@index([language])
  @@index([contentHash])
  @@index([repositoryId])
  @@index([questionId])
  @@index([processedAt])
  @@map("contents")
}

// Enhanced Content chunks - Phase 2
model ContentChunk {
  id        String @id @default(cuid())
  contentId String
  
  // Chunk metadata
  chunkText String    // The actual text chunk
  chunkHash String    @unique // SHA256 hash for deduplication
  sequence  Int       // Order within the content
  
  // Chunk boundaries
  startLine Int?      // Starting line number
  endLine   Int?      // Ending line number
  startChar Int?      // Starting character position
  endChar   Int?      // Ending character position
  
  // Embedding metadata
  embeddingStatus EmbeddingStatus @default(PENDING)
  embeddingError  String?
  embeddedAt      DateTime?
  
  // Token information for cost tracking
  tokenCount      Int?
  
  // Relationships
  content    Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  embeddings Embedding[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([contentId])
  @@index([chunkHash])
  @@index([embeddingStatus])
  @@index([sequence])
  @@map("content_chunks")
}

// Vector embeddings - Phase 2
model Embedding {
  id      String @id @default(cuid())
  
  // Embedding metadata
  vector     Unsupported("vector(1536)") // Vector embedding using pgvector
  dimensions Int          @default(1536) // Vector dimensions
  model      String       // Embedding model used (e.g., 'text-embedding-3-small')
  
  // Cost tracking
  tokenCount Int?         // Tokens used for generation
  cost       Decimal?     // Cost in USD
  
  // Foreign keys (content can have embeddings, chunks have embeddings)
  contentId      String?
  contentChunkId String?
  
  // Relationships  
  content      Content?      @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentChunk ContentChunk? @relation(fields: [contentChunkId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([contentId])
  @@index([contentChunkId])
  @@index([model])
  @@index([dimensions])
  @@map("embeddings")
}

// Enhanced Ingestion job tracking - Phase 2
model IngestionJob {
  id          String @id @default(cuid())
  
  // Job metadata
  jobType     IngestionJobType
  status      JobStatus @default(PENDING)
  priority    Int       @default(5) // 1-10, higher = more priority
  
  // Job data and configuration
  jobData     Json      // Job-specific data
  config      Json?     // Job configuration
  
  // Progress tracking
  totalItems    Int?    // Total items to process
  processedItems Int @default(0) // Items processed so far
  failedItems   Int @default(0) // Items that failed
  
  // Execution metadata
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?
  retryCount    Int @default(0)
  maxRetries    Int @default(3)
  
  // Foreign keys
  sourceId      String?
  repositoryId  String?
  questionId    String?
  
  // Relationships
  source       Source?     @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  repository   Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  question     Question?   @relation(fields: [questionId], references: [id], onDelete: SetNull)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([jobType])
  @@index([status])
  @@index([priority])
  @@index([sourceId])
  @@index([repositoryId])
  @@index([questionId])
  @@index([createdAt])
  @@map("ingestion_jobs")
}

// Search history (from Phase 1)
model Search {
  id         String   @id @default(cuid())
  userId     String?
  query      String
  filters    Json?    // Store search filters as JSON
  resultCount Int     @default(0)
  took       Int      // Response time in milliseconds
  createdAt  DateTime @default(now())

  // Relations
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("searches")
}

// User favorites (from Phase 1)
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("favorites")
}

// Enums for Phase 2
enum SourceType {
  GITHUB
  STACKOVERFLOW
  DOCUMENTATION
  BLOG
}

enum ContentType {
  REPOSITORY_FILE
  STACKOVERFLOW_QUESTION
  STACKOVERFLOW_ANSWER
  DOCUMENTATION_PAGE
  BLOG_POST
}

enum IngestionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  SKIPPED
}

enum EmbeddingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum IngestionJobType {
  GITHUB_DISCOVER_REPOSITORIES
  GITHUB_INGEST_REPOSITORY
  GITHUB_PROCESS_CONTENT
  STACKOVERFLOW_DISCOVER_QUESTIONS
  STACKOVERFLOW_INGEST_QUESTION
  GENERATE_EMBEDDINGS
  CHUNK_CONTENT
}

// =======================
// PHASE 5: AUTHENTICATION
// =======================

// Enhanced User model with authentication fields
model UserAuth {
  id                  String   @id @default(cuid())
  email               String   @unique
  username            String?  @unique
  displayName         String?
  avatarUrl           String?
  
  // Password authentication
  passwordHash        String?
  emailVerified       Boolean  @default(false)
  emailVerificationToken String? @unique
  
  // GitHub OAuth
  githubId            String?  @unique
  githubUsername      String?
  githubAccessToken   String?  // Encrypted
  
  // User roles and status
  role                UserRole @default(USER)
  isActive            Boolean  @default(true)
  isBanned            Boolean  @default(false)
  
  // User preferences
  preferences         Json     @default("{}")
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastLoginAt         DateTime?
  
  // Relationships
  sessions            UserSession[]
  searchHistory       SearchHistory[]
  favorites           UserFavorite[]
  preferences_        UserPreferences?
  rateLimits          UserRateLimit?
  
  @@map("user_auth")
}

// User authentication sessions
model UserSession {
  id                  String   @id @default(cuid())
  userId              String
  
  // Token management
  refreshToken        String   @unique
  accessTokenHash     String?
  jwtId               String   @unique // For JWT blacklisting
  
  // Session metadata
  expiresAt           DateTime
  userAgent           String?
  ipAddress           String?
  deviceInfo          Json?    // Browser, OS, etc.
  
  // Session status
  isRevoked           Boolean  @default(false)
  revokedAt           DateTime?
  revokeReason        String?
  
  // Timestamps
  createdAt           DateTime @default(now())
  lastUsedAt          DateTime @default(now())
  
  // Relationships
  user                UserAuth @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_sessions")
  @@index([userId, expiresAt])
  @@index([refreshToken])
  @@index([accessTokenHash])
}

// User search history
model SearchHistory {
  id                  String   @id @default(cuid())
  userId              String
  
  // Search details
  query               String
  filters             Json     @default("{}")
  searchMethod        String   // 'hybrid', 'vector', 'fulltext'
  
  // Search results metadata
  resultsCount        Int
  searchTime          Int      // milliseconds
  clickedResults      Json     @default("[]") // Array of clicked result IDs
  
  // Search context
  userAgent           String?
  ipAddress           String?
  
  // Timestamps
  createdAt           DateTime @default(now())
  
  // Relationships
  user                UserAuth @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("search_history")
  @@index([userId, createdAt])
  @@index([query])
  @@index([createdAt])
}

// User favorites/bookmarks
model UserFavorite {
  id                  String   @id @default(cuid())
  userId              String
  
  // Favorited content
  contentId           String?  // Reference to Content if available
  resultData          Json     // Stored search result data
  
  // Organization
  title               String
  description         String?
  tags                String[] @default([])
  notes               String?
  
  // Metadata
  originalQuery       String?  // Query that led to this result
  sourceUrl           String?
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Relationships
  user                UserAuth @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_favorites")
  @@index([userId, createdAt])
  @@index([userId, tags])
  @@unique([userId, contentId])
}

// User preferences and settings
model UserPreferences {
  userId              String   @id
  
  // Search preferences
  preferredLanguages  String[] @default([])
  preferredSources    String[] @default([])
  defaultSearchMethod String   @default("hybrid") // 'hybrid', 'vector', 'fulltext'
  
  // UI preferences
  theme               String   @default("system") // 'light', 'dark', 'system'
  resultsPerPage      Int      @default(20)
  
  // Notification preferences
  emailNotifications  Boolean  @default(true)
  searchSuggestions   Boolean  @default(true)
  
  // Privacy preferences
  trackSearchHistory  Boolean  @default(true)
  publicProfile       Boolean  @default(false)
  shareStatistics     Boolean  @default(false)
  
  // Advanced settings
  searchSettings      Json     @default("{}")
  
  // Timestamps
  updatedAt           DateTime @updatedAt
  
  // Relationships
  user                UserAuth @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_preferences")
}

// User rate limiting
model UserRateLimit {
  userId              String   @id
  
  // Rate limit tracking
  dailySearches       Int      @default(0)
  monthlySearches     Int      @default(0)
  
  // Time tracking
  lastSearchDate      DateTime @default(now())
  lastSearchMonth     DateTime @default(now())
  
  // Rate limit configuration
  rateLimitTier       RateLimitTier @default(FREE)
  dailyLimit          Int      @default(100)
  monthlyLimit        Int      @default(1000)
  
  // Penalties
  isThrottled         Boolean  @default(false)
  throttledUntil      DateTime?
  violationCount      Int      @default(0)
  
  // Timestamps
  updatedAt           DateTime @updatedAt
  
  // Relationships
  user                UserAuth @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_rate_limits")
}

// Password reset tokens
model PasswordResetToken {
  id                  String   @id @default(cuid())
  email               String
  token               String   @unique
  expiresAt           DateTime
  isUsed              Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  
  @@map("password_reset_tokens")
  @@index([email])
  @@index([token])
}

// Enums for authentication
enum UserRole {
  USER
  PREMIUM
  ADMIN
  MODERATOR
}

enum RateLimitTier {
  FREE
  PREMIUM
  UNLIMITED
}