{
    "dashboard": {
        "id": null,
        "title": "CodeSenseiSearch - Log Analysis",
        "tags": [
            "codesenseisearch",
            "logs",
            "analysis",
            "loki"
        ],
        "style": "dark",
        "timezone": "browser",
        "refresh": "30s",
        "time": {
            "from": "now-1h",
            "to": "now"
        },
        "panels": [
            {
                "id": 1,
                "title": "Log Volume by Service",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "sum by (service) (rate({service=~\"codesenseisearch-.*\"}[5m]))",
                        "legendFormat": "{{ service }}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "palette-classic"
                        },
                        "custom": {
                            "drawStyle": "line",
                            "lineInterpolation": "linear",
                            "barAlignment": 0,
                            "lineWidth": 2,
                            "fillOpacity": 20,
                            "gradientMode": "opacity",
                            "spanNulls": false,
                            "insertNulls": false,
                            "showPoints": "never",
                            "pointSize": 5,
                            "stacking": {
                                "mode": "normal",
                                "group": "A"
                            },
                            "axisPlacement": "auto",
                            "axisLabel": "",
                            "scaleDistribution": {
                                "type": "linear"
                            },
                            "thresholdsStyle": {
                                "mode": "off"
                            }
                        },
                        "mappings": [],
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "red",
                                    "value": 80
                                }
                            ]
                        },
                        "unit": "logs/sec"
                    }
                }
            },
            {
                "id": 2,
                "title": "Log Levels Distribution",
                "type": "piechart",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "sum by (level) (rate({service=~\"codesenseisearch-.*\"}[5m]))",
                        "legendFormat": "{{ level }}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "palette-classic"
                        },
                        "custom": {
                            "hideFrom": {
                                "legend": false,
                                "tooltip": false,
                                "vis": false
                            }
                        },
                        "mappings": [],
                        "unit": "logs/sec"
                    },
                    "overrides": [
                        {
                            "matcher": {
                                "id": "byName",
                                "options": "error"
                            },
                            "properties": [
                                {
                                    "id": "color",
                                    "value": {
                                        "mode": "fixed",
                                        "fixedColor": "red"
                                    }
                                }
                            ]
                        },
                        {
                            "matcher": {
                                "id": "byName",
                                "options": "warn"
                            },
                            "properties": [
                                {
                                    "id": "color",
                                    "value": {
                                        "mode": "fixed",
                                        "fixedColor": "yellow"
                                    }
                                }
                            ]
                        },
                        {
                            "matcher": {
                                "id": "byName",
                                "options": "info"
                            },
                            "properties": [
                                {
                                    "id": "color",
                                    "value": {
                                        "mode": "fixed",
                                        "fixedColor": "blue"
                                    }
                                }
                            ]
                        }
                    ]
                }
            },
            {
                "id": 3,
                "title": "Error Rate by Service",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 0,
                    "y": 8
                },
                "targets": [
                    {
                        "expr": "sum by (service) (rate({service=~\"codesenseisearch-.*\",level=\"error\"}[5m])) / sum by (service) (rate({service=~\"codesenseisearch-.*\"}[5m]))",
                        "legendFormat": "{{ service }}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "thresholds"
                        },
                        "custom": {
                            "displayMode": "list",
                            "orientation": "horizontal"
                        },
                        "mappings": [],
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 0.01
                                },
                                {
                                    "color": "red",
                                    "value": 0.05
                                }
                            ]
                        },
                        "unit": "percentunit"
                    }
                }
            },
            {
                "id": 4,
                "title": "Recent Errors",
                "type": "logs",
                "gridPos": {
                    "h": 8,
                    "w": 18,
                    "x": 6,
                    "y": 8
                },
                "targets": [
                    {
                        "expr": "{service=~\"codesenseisearch-.*\",level=\"error\"}",
                        "refId": "A"
                    }
                ],
                "options": {
                    "showTime": true,
                    "showLabels": true,
                    "showCommonLabels": false,
                    "wrapLogMessage": true,
                    "prettifyLogMessage": false,
                    "enableLogDetails": true,
                    "dedupStrategy": "none",
                    "sortOrder": "Descending"
                }
            },
            {
                "id": 5,
                "title": "Search Performance Logs",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, sum(rate({service=\"search-engine\"} | json | response_time > 0 [5m])) by (le))",
                        "legendFormat": "95th percentile",
                        "refId": "A"
                    },
                    {
                        "expr": "histogram_quantile(0.50, sum(rate({service=\"search-engine\"} | json | response_time > 0 [5m])) by (le))",
                        "legendFormat": "50th percentile",
                        "refId": "B"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "palette-classic"
                        },
                        "custom": {
                            "drawStyle": "line",
                            "lineInterpolation": "linear",
                            "barAlignment": 0,
                            "lineWidth": 2,
                            "fillOpacity": 10,
                            "gradientMode": "none",
                            "spanNulls": false,
                            "insertNulls": false,
                            "showPoints": "never",
                            "pointSize": 5,
                            "stacking": {
                                "mode": "none",
                                "group": "A"
                            },
                            "axisPlacement": "auto",
                            "axisLabel": "",
                            "scaleDistribution": {
                                "type": "linear"
                            },
                            "thresholdsStyle": {
                                "mode": "off"
                            }
                        },
                        "mappings": [],
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "red",
                                    "value": 80
                                }
                            ]
                        },
                        "unit": "ms"
                    }
                }
            },
            {
                "id": 6,
                "title": "Security Events",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "sum by (event_type) (rate({service=~\"codesenseisearch-.*\",category=\"security\"}[5m]))",
                        "legendFormat": "{{ event_type }}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "palette-classic"
                        },
                        "custom": {
                            "drawStyle": "line",
                            "lineInterpolation": "linear",
                            "barAlignment": 0,
                            "lineWidth": 2,
                            "fillOpacity": 20,
                            "gradientMode": "opacity",
                            "spanNulls": false,
                            "insertNulls": false,
                            "showPoints": "never",
                            "pointSize": 5,
                            "stacking": {
                                "mode": "normal",
                                "group": "A"
                            },
                            "axisPlacement": "auto",
                            "axisLabel": "",
                            "scaleDistribution": {
                                "type": "linear"
                            },
                            "thresholdsStyle": {
                                "mode": "off"
                            }
                        },
                        "mappings": [],
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "red",
                                    "value": 80
                                }
                            ]
                        },
                        "unit": "events/sec"
                    }
                }
            },
            {
                "id": 7,
                "title": "Top Error Messages",
                "type": "table",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 24
                },
                "targets": [
                    {
                        "expr": "topk(10, sum by (message) (rate({service=~\"codesenseisearch-.*\",level=\"error\"}[1h])))",
                        "refId": "A",
                        "format": "table"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "thresholds"
                        },
                        "custom": {
                            "displayMode": "basic",
                            "inspect": false
                        },
                        "mappings": [],
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "red",
                                    "value": 80
                                }
                            ]
                        },
                        "unit": "errors/hour"
                    }
                },
                "transformations": [
                    {
                        "id": "organize",
                        "options": {
                            "excludeByName": {
                                "Time": true,
                                "__name__": true
                            },
                            "indexByName": {},
                            "renameByName": {
                                "message": "Error Message",
                                "Value": "Count"
                            }
                        }
                    }
                ]
            },
            {
                "id": 8,
                "title": "Failed Authentication Attempts",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 12,
                    "y": 24
                },
                "targets": [
                    {
                        "expr": "sum(rate({service=~\"codesenseisearch-.*\"} |= \"authentication failed\" [5m]))",
                        "legendFormat": "Failed Attempts/min",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "thresholds"
                        },
                        "custom": {
                            "displayMode": "basic"
                        },
                        "mappings": [],
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 5
                                },
                                {
                                    "color": "red",
                                    "value": 20
                                }
                            ]
                        },
                        "unit": "attempts/min"
                    }
                }
            },
            {
                "id": 9,
                "title": "Search Success Rate",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 18,
                    "y": 24
                },
                "targets": [
                    {
                        "expr": "sum(rate({service=\"search-engine\"} | json | results_count > \"0\" [5m])) / sum(rate({service=\"search-engine\"}[5m]))",
                        "legendFormat": "Success Rate",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "thresholds"
                        },
                        "custom": {
                            "displayMode": "basic"
                        },
                        "mappings": [],
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "red",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 0.8
                                },
                                {
                                    "color": "green",
                                    "value": 0.95
                                }
                            ]
                        },
                        "unit": "percentunit"
                    }
                }
            },
            {
                "id": 10,
                "title": "Log Pattern Analysis",
                "type": "heatmap",
                "gridPos": {
                    "h": 8,
                    "w": 24,
                    "x": 0,
                    "y": 28
                },
                "targets": [
                    {
                        "expr": "sum by (service, level) (rate({service=~\"codesenseisearch-.*\"}[5m]))",
                        "refId": "A",
                        "format": "heatmap"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "spectrum"
                        },
                        "custom": {
                            "hideFrom": {
                                "legend": false,
                                "tooltip": false,
                                "vis": false
                            }
                        },
                        "mappings": [],
                        "unit": "logs/sec"
                    }
                }
            }
        ],
        "templating": {
            "list": [
                {
                    "current": {
                        "selected": false,
                        "text": "All",
                        "value": "$__all"
                    },
                    "definition": "label_values({service=~\"codesenseisearch-.*\"}, service)",
                    "hide": 0,
                    "includeAll": true,
                    "label": "Service",
                    "multi": true,
                    "name": "service",
                    "options": [],
                    "query": {
                        "query": "label_values({service=~\"codesenseisearch-.*\"}, service)",
                        "refId": "Loki-service-Variable-Query"
                    },
                    "refresh": 1,
                    "regex": "",
                    "skipUrlSync": false,
                    "sort": 1,
                    "type": "query"
                },
                {
                    "current": {
                        "selected": false,
                        "text": "All",
                        "value": "$__all"
                    },
                    "definition": "label_values({service=~\"codesenseisearch-.*\"}, level)",
                    "hide": 0,
                    "includeAll": true,
                    "label": "Log Level",
                    "multi": true,
                    "name": "level",
                    "options": [],
                    "query": {
                        "query": "label_values({service=~\"codesenseisearch-.*\"}, level)",
                        "refId": "Loki-level-Variable-Query"
                    },
                    "refresh": 1,
                    "regex": "",
                    "skipUrlSync": false,
                    "sort": 1,
                    "type": "query"
                }
            ]
        },
        "annotations": {
            "list": [
                {
                    "builtIn": 1,
                    "datasource": {
                        "type": "grafana",
                        "uid": "-- Grafana --"
                    },
                    "enable": true,
                    "hide": true,
                    "iconColor": "rgba(0, 211, 255, 1)",
                    "name": "Annotations & Alerts",
                    "type": "dashboard"
                }
            ]
        },
        "editable": true,
        "fiscalYearStartMonth": 0,
        "graphTooltip": 0,
        "links": [],
        "liveNow": false,
        "schemaVersion": 37,
        "timepicker": {},
        "uid": "codesenseisearch-logs",
        "version": 1,
        "weekStart": ""
    }
}