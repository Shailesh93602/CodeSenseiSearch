{
    "dashboard": {
        "id": null,
        "title": "CodeSenseiSearch - Database Monitoring",
        "tags": [
            "codesenseisearch",
            "database",
            "postgres",
            "redis"
        ],
        "style": "dark",
        "timezone": "browser",
        "refresh": "30s",
        "time": {
            "from": "now-1h",
            "to": "now"
        },
        "panels": [
            {
                "id": 1,
                "title": "PostgreSQL Status",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 0,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "pg_up",
                        "legendFormat": "{{instance}}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "thresholds"
                        },
                        "custom": {
                            "displayMode": "list"
                        },
                        "mappings": [
                            {
                                "options": {
                                    "0": {
                                        "color": "red",
                                        "index": 0,
                                        "text": "Down"
                                    },
                                    "1": {
                                        "color": "green",
                                        "index": 1,
                                        "text": "Up"
                                    }
                                },
                                "type": "value"
                            }
                        ],
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "red",
                                    "value": null
                                },
                                {
                                    "color": "green",
                                    "value": 1
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 2,
                "title": "Redis Status",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 6,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "redis_up",
                        "legendFormat": "{{instance}}",
