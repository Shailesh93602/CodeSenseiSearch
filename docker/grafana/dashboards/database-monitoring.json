                                {
                                    "color": "yellow",
                                    "value": 50
                                },
                                {
                                    "color": "red",
                                    "value": 80
                                }
                            ]
                        },
                        "unit": "short"
                    }
                }
            },
            {
                "id": 4,
                "title": "Database Size",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 18,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "pg_database_size_bytes",
                        "legendFormat": "{{datname}}",
                        "refId": "A"
