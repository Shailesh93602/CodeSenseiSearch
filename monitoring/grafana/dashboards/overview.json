{
    "dashboard": {
        "id": null,
        "title": "CodeSenseiSearch - Application Overview",
        "tags": [
            "codesenseisearch",
            "overview"
        ],
        "timezone": "browser",
        "refresh": "30s",
        "time": {
            "from": "now-1h",
            "to": "now"
        },
        "panels": [
            {
                "id": 1,
                "title": "System Overview",
                "type": "stat",
                "targets": [
                    {
                        "expr": "up{job=\"codesenseisearch-api\"}",
                        "legendFormat": "API Status"
                    },
                    {
                        "expr": "up{job=\"codesenseisearch-web\"}",
                        "legendFormat": "Web Status"
                    },
                    {
                        "expr": "up{job=\"postgres\"}",
                        "legendFormat": "Database Status"
                    },
                    {
                        "expr": "up{job=\"redis\"}",
                        "legendFormat": "Redis Status"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 24,
                    "x": 0,
                    "y": 0
                },
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "thresholds"
                        },
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "red",
                                    "value": 0
                                },
                                {
                                    "color": "green",
                                    "value": 1
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 2,
                "title": "Request Rate",
                "type": "graph",
                "targets": [
                    {
                        "expr": "rate(http_requests_total{job=\"codesenseisearch-api\"}[5m])",
                        "legendFormat": "API Requests/sec"
                    },
                    {
                        "expr": "rate(http_requests_total{job=\"codesenseisearch-web\"}[5m])",
                        "legendFormat": "Web Requests/sec"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 8
                },
                "yAxes": [
                    {
                        "label": "Requests/sec",
                        "min": 0
                    }
                ]
            },
            {
                "id": 3,
                "title": "Response Time (95th percentile)",
                "type": "graph",
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"codesenseisearch-api\"}[5m]))",
                        "legendFormat": "API Response Time"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 8
                },
                "yAxes": [
                    {
                        "label": "Seconds",
                        "min": 0
                    }
                ]
            },
            {
                "id": 4,
                "title": "Error Rate",
                "type": "graph",
                "targets": [
                    {
                        "expr": "rate(http_requests_total{job=\"codesenseisearch-api\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"codesenseisearch-api\"}[5m])",
                        "legendFormat": "API Error Rate"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 16
                },
                "yAxes": [
                    {
                        "label": "Error Rate",
                        "min": 0,
                        "max": 1
                    }
                ]
            },
            {
                "id": 5,
                "title": "Database Connections",
                "type": "graph",
                "targets": [
                    {
                        "expr": "pg_stat_database_numbackends",
                        "legendFormat": "Active Connections"
                    },
                    {
                        "expr": "pg_settings_max_connections",
                        "legendFormat": "Max Connections"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 16
                },
                "yAxes": [
                    {
                        "label": "Connections",
                        "min": 0
                    }
                ]
            },
            {
                "id": 6,
                "title": "Memory Usage",
                "type": "graph",
                "targets": [
                    {
                        "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
                        "legendFormat": "Memory Usage %"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 24
                },
                "yAxes": [
                    {
                        "label": "Percentage",
                        "min": 0,
                        "max": 100
                    }
                ]
            },
            {
                "id": 7,
                "title": "CPU Usage",
                "type": "graph",
                "targets": [
                    {
                        "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
                        "legendFormat": "CPU Usage %"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 24
                },
                "yAxes": [
                    {
                        "label": "Percentage",
                        "min": 0,
                        "max": 100
                    }
                ]
            },
            {
                "id": 8,
                "title": "Search Performance",
                "type": "graph",
                "targets": [
                    {
                        "expr": "rate(search_requests_total[5m])",
                        "legendFormat": "Search Requests/sec"
                    },
                    {
                        "expr": "histogram_quantile(0.95, rate(search_duration_seconds_bucket[5m]))",
                        "legendFormat": "Search Response Time (95th)"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 24,
                    "x": 0,
                    "y": 32
                },
                "yAxes": [
                    {
                        "label": "Requests/sec | Seconds",
                        "min": 0
                    }
                ]
            },
            {
                "id": 9,
                "title": "Queue Status",
                "type": "graph",
                "targets": [
                    {
                        "expr": "bullmq_queue_waiting_count",
                        "legendFormat": "{{ queue }} - Waiting"
                    },
                    {
                        "expr": "bullmq_queue_active_count",
                        "legendFormat": "{{ queue }} - Active"
                    },
                    {
                        "expr": "bullmq_queue_completed_count",
                        "legendFormat": "{{ queue }} - Completed"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 24,
                    "x": 0,
                    "y": 40
                }
            }
        ]
    }
}